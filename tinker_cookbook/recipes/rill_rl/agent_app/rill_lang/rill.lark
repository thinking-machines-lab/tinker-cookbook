// ============================================================
// RILL — a small, deterministic dataflow-imperative DSL.
// This Lark grammar is the source of truth for the language.
// Parser: LALR(1). Keywords are reserved.
// ============================================================

start: stmt*

?stmt: bind
     | emit_stmt
     | when_stmt
     | sustain_stmt
     | walk_stmt
     | forge_stmt
     | give_stmt
     | halt_stmt
     | skip_stmt
     | expr_stmt

// rightward binding: value flows INTO a name   (e.g.  3 + 4 -> total)
bind:       expr "->" NAME
emit_stmt:  "emit" expr
give_stmt:  "give" [expr]
halt_stmt:  "halt"
skip_stmt:  "skip"
expr_stmt:  expr

block: "{" stmt* "}"

when_stmt:  "when" expr block elsewhen* [otherwise]
elsewhen:   "elsewhen" expr block
otherwise:  "otherwise" block

sustain_stmt: "sustain" expr block
walk_stmt:    "walk" NAME "across" expr block

forge_stmt: "forge" NAME "(" [params] ")" block
params:     NAME ("," NAME)*

// ---- expressions, lowest precedence first ----
?expr: or_expr

?or_expr:  and_expr ("either" and_expr)*
?and_expr: not_expr ("both" not_expr)*
?not_expr: "flip" not_expr   -> flip
         | cmp_expr
?cmp_expr: add_expr (cmp_op add_expr)?
?add_expr: add_expr "+" mul_expr -> add
         | add_expr "-" mul_expr -> sub
         | mul_expr
?mul_expr: mul_expr "*" unary -> mul
         | mul_expr "/" unary -> div
         | mul_expr "%" unary -> mod
         | unary
?unary: "-" unary -> neg
      | postfix
?postfix: postfix "(" [args] ")" -> call
        | postfix "@" atom        -> index
        | atom
args: expr ("," expr)*

?atom: INT          -> int
     | FLOAT        -> float
     | STRING       -> string
     | "yes"        -> true
     | "no"         -> false
     | "void"       -> nil
     | list
     | NAME         -> var
     | "(" expr ")"

list: "[" [expr ("," expr)*] "]"

cmp_op: "="  -> eq
      | "!=" -> neq
      | "<"  -> lt
      | ">"  -> gt
      | "<=" -> le
      | ">=" -> ge

// ---- terminals ----
NAME:   /[a-zA-Z_][a-zA-Z_0-9]*/
INT:    /[0-9]+/
FLOAT:  /[0-9]+\.[0-9]+/
STRING: /"(\\.|[^"\\])*"/

COMMENT: /~[^\n]*/
%ignore COMMENT
%ignore /[ \t\r\n]+/
